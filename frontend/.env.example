# ── Backend URL (your Render deployment URL) ──
# Example: https://evidence-ai-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── PostgreSQL database URL (with connection pooler for Vercel serverless) ──
# Get a free PostgreSQL from https://neon.tech or https://supabase.com
# For Neon: use the pooled connection string for DATABASE_URL
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech:5432/dbname?sslmode=require

# ── Direct URL (without pooler — used by Prisma migrate) ──
# For Neon: use the direct (non-pooled) connection string
DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech:5432/dbname?sslmode=require
